# Meeting Bot - Environment Variables

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_CHAT_ID=your_admin_chat_id_here

# Google Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Bitrix24 Configuration (optional)
BITRIX_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/YOUR_USER_ID/YOUR_WEBHOOK_KEY/
BITRIX_USER_ID=1
BITRIX_WEBHOOK_KEY=your_webhook_key
BITRIX_RESPONSIBLE_ID=1
BITRIX_PROJECT_ID=

# Recording Configuration
REC_DIR=/tmp/recordings
REC_MAX_SECONDS=3600

# Server Configuration
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Chrome/Puppeteer Configuration
CHROME_BIN=/usr/bin/google-chrome-stable

# Render Deployment (optional)
RENDER_EXTERNAL_URL=
